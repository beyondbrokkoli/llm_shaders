// swarm.comp
#version 450

layout(local_size_x = 256) in;

struct Particle {
    float x, y, z, pad;
};

layout(std430, binding = 0) readonly buffer InSwarm {
    Particle inParticles[];
};

layout(std430, binding = 1) writeonly buffer OutSwarm {
    Particle outParticles[];
};

// PAST FRAME MEMORY FIELD
layout(std430, binding = 2) readonly buffer PrevSwarm {
    Particle prevParticles[];
};

layout(std430, binding = 3) buffer DrawCmd {
    uint vertexCount;
    uint instanceCount;
    uint firstVertex;
    uint firstInstance;
} drawCmd;

layout(push_constant) uniform PushConstants {
    float dt;
    float time;
    int state;
    int push;
    int pull;
    uint total_active_count;
    uint offsets[4];
    uint counts[4];
} pc;

const float TAU = 6.28318530718;

uint pcg_hash(uint seed) {
    uint state = seed * 747796405u + 2891336453u;
    uint word = ((state >> ((state >> 28u) + 4u)) ^ state) * 277803737u;
    return (word >> 22u) ^ word;
}

float randf(uint n) {
    return float(pcg_hash(n)) / 4294967295.0;
}
// THE VACCINE: Prevents division by zero!
vec3 safeNormalize(vec3 v) {
    float len = length(v);
    if (len < 0.0001) return vec3(0.0);
    return v / len;
}
vec3 readPos(uint idx) {
    return vec3(
        prevParticles[idx].x,
        prevParticles[idx].y,
        prevParticles[idx].z
    );
}

void main() {
    uint id = gl_GlobalInvocationID.x;

    if (id >= pc.total_active_count) {
        return;
    }

    vec3 selfPos = readPos(id);

    // ========================================================
    // HEAVY MEMORY ACCESS FIELD SAMPLING
    // ========================================================

    uint h0 = pcg_hash(id * 17u + uint(pc.time * 1000.0));
    uint h1 = pcg_hash(id * 31u + 911u);
    uint h2 = pcg_hash(id * 73u + 1771u);
    uint h3 = pcg_hash(id * 127u + 13u);

    uint s0 = h0 % pc.total_active_count;
    uint s1 = h1 % pc.total_active_count;
    uint s2 = h2 % pc.total_active_count;
    uint s3 = h3 % pc.total_active_count;

    vec3 p0 = readPos(s0);
    vec3 p1 = readPos(s1);
    vec3 p2 = readPos(s2);
    vec3 p3 = readPos(s3);

    // Use the vaccine here!
    vec3 field =
        safeNormalize(p0 - selfPos) * 0.9 +
        safeNormalize(p1 - selfPos) * 0.7 +
        safeNormalize(p2 - selfPos) * 0.5 +
        safeNormalize(p3 - selfPos) * 0.3;

    vec3 vortex = vec3(
        field.z - field.y,
        field.x - field.z,
        field.y - field.x
    );

    vec3 finalPos = selfPos;

    // ========================================================
    // SLICE 0 : CPU CORE -> GALACTIC OCEAN
    // ========================================================
    if (id >= pc.offsets[0] && id < pc.offsets[0] + pc.counts[0]) {

        // THE FIX: Anchor the particle to the AVX2 CPU math!
        vec3 cpuPos = vec3(inParticles[id].x, inParticles[id].y, inParticles[id].z);

        float radial = length(cpuPos.xz);

        float wave =
            sin(radial * 0.0015 - pc.time * 2.0) +
            cos(cpuPos.x * 0.003 + pc.time * 0.7) +
            sin(cpuPos.z * 0.002 - pc.time * 1.3);

        // Reset finalPos to the CPU baseline before applying GPU distortions
        finalPos = cpuPos; 
        
        finalPos += vortex * 120.0;
        finalPos.y += wave * 450.0;

        finalPos.x += sin(pc.time + cpuPos.y * 0.0007) * 90.0;
        finalPos.z += cos(pc.time + cpuPos.x * 0.0007) * 90.0;
    }
    // ========================================================
    // SLICE 1 : QUANTUM LATTICE
    // ========================================================
    else if (id >= pc.offsets[1] &&
             id < pc.offsets[1] + pc.counts[1]) {

        uint local_id = id - pc.offsets[1];

        float spacing = 1400.0;

        uint gridSize = uint(pow(float(pc.counts[1]), 1.0 / 3.0));
        if (gridSize == 0u) {
            gridSize = 1u;
        }

        vec3 gridPos;

        gridPos.x =
            float(local_id % gridSize) * spacing -
            float(gridSize) * spacing * 0.5;

        gridPos.y =
            float((local_id / gridSize) % gridSize) * spacing -
            float(gridSize) * spacing * 0.5;

        gridPos.z =
            float(local_id / (gridSize * gridSize)) * spacing -
            float(gridSize) * spacing * 0.5;

        float pulse =
            sin(length(gridPos) * 0.0015 - pc.time * 3.0);

        vec3 curl = cross(normalize(gridPos + 0.01), vortex);

        finalPos =
            gridPos +
            curl * 700.0 +
            normalize(field) * pulse * 1500.0;
    }

    // ========================================================
    // SLICE 2 : MEMORY BOIDS
    // ========================================================
    else if (id >= pc.offsets[2] &&
             id < pc.offsets[2] + pc.counts[2]) {

        uint local_id = id - pc.offsets[2];

        vec3 velocity =
            (p0 + p1 + p2 + p3) * 0.25 - selfPos;

        vec3 tangent = safeNormalize(vec3( // <--- HERE
            -selfPos.z,
             sin(pc.time + float(local_id) * 0.01) * 0.3,
             selfPos.x
        ));

        finalPos += safeNormalize(velocity) * 220.0; // <--- HERE
        finalPos += tangent * 180.0;
        finalPos += vortex * 150.0;

        float attract = sin(float(local_id) * 0.0001 + pc.time);
        finalPos += safeNormalize(selfPos) * attract * 80.0; // <--- HERE
    }

    // ========================================================
    // SLICE 3 : RELATIVISTIC METEOR STREAM
    // ========================================================
    else if (id >= pc.offsets[3] &&
             id < pc.offsets[3] + pc.counts[3]) {

        uint local_id = id - pc.offsets[3];

        float seed0 = randf(local_id);
        float seed1 = randf(local_id * 11u);

        float angle = seed0 * TAU;

        float radius = 35000.0 + seed1 * 12000.0;

        vec3 orbitCenter = vec3(
            cos(angle) * radius,
            sin(pc.time * 0.2 + angle) * 8000.0,
            sin(angle) * radius
        );

        vec3 dir = safeNormalize(-orbitCenter + vortex * 4000.0); // <--- HERE

        float speed =
            12000.0 +
            sin(float(local_id) * 0.13) * 4000.0;

        float t =
            mod(pc.time * speed * 0.08 + float(local_id), 80000.0);

        finalPos = orbitCenter + dir * t;
    }

    outParticles[id].x = finalPos.x;
    outParticles[id].y = finalPos.y;
    outParticles[id].z = finalPos.z;

    // velocity magnitude proxy for shading
    outParticles[id].pad =
        clamp(length(finalPos - selfPos) * 0.002, 0.0, 1.0);

    if (gl_GlobalInvocationID.x == 0) {
        drawCmd.vertexCount = pc.total_active_count;
        drawCmd.instanceCount = 1;
        drawCmd.firstVertex = 0;
        drawCmd.firstInstance = 0;
    }
}

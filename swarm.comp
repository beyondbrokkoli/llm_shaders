#version 450
layout(local_size_x = 256) in;

struct Particle { float x, y, z, pad; };

// The Particle Buffers
layout(std430, binding = 0) readonly buffer InSwarm { Particle inParticles[]; };
layout(std430, binding = 1) writeonly buffer OutSwarm { Particle outParticles[]; };

// The Command Buffer
layout(std430, binding = 3) buffer DrawCmd {
    uint vertexCount; uint instanceCount; uint firstVertex; uint firstInstance;
} drawCmd;

// ========================================================
// THE TEMPORAL PING-PONG GRIDS
// ========================================================
layout(std430, binding = 4) readonly buffer GridPast { uint gridP[]; };
layout(std430, binding = 5) buffer GridFuture { uint gridF[]; };

layout(push_constant) uniform PushConstants {
    float dt; float time; int state; int push; int pull;
    uint total_active_count;
    uint offsets[4]; uint counts[4];
} pc;

uint pcg_hash(uint seed) {
    uint state = seed * 747796405u + 2891336453u;
    uint word = ((state >> ((state >> 28u) + 4u)) ^ state) * 277803737u;
    return (word >> 22u) ^ word;
}

#define GRID_SIZE 128
#define CELL_SIZE 500.0 

uint GetCellIndex(vec3 pos) {
    vec3 offsetPos = pos + vec3(GRID_SIZE * CELL_SIZE * 0.5);
    ivec3 cell3D = ivec3(offsetPos / CELL_SIZE);
    cell3D = clamp(cell3D, ivec3(0), ivec3(GRID_SIZE - 1));
    return uint(cell3D.x + cell3D.y * GRID_SIZE + cell3D.z * GRID_SIZE * GRID_SIZE);
}

void main() {
    uint id = gl_GlobalInvocationID.x;
    if (id >= pc.total_active_count) return;

    // Read where WE were last frame (Temporal Inertia!)
    vec3 myPos = vec3(inParticles[id].x, inParticles[id].y, inParticles[id].z);
    
    vec3 finalPos;
    float materialID = 0.0;

    // ========================================================
    // SLICE 0: CPU CORE (The AVX2 Singularity)
    // ========================================================
    if (id >= pc.offsets[0] && id < pc.offsets[0] + pc.counts[0]) {
        // CPU gives us the base, we add a gentle GPU fluid ripple
        float ripple = sin((myPos.x * 0.01) + (pc.time * 2.0)) * 50.0 +
                       cos((myPos.z * 0.01) + (pc.time * 2.0)) * 50.0;
        finalPos = myPos + vec3(0.0, ripple, 0.0);
        materialID = 0.0 + clamp((finalPos.y + 10000.0) / 20000.0, 0.0, 0.99);
    }
    // ========================================================
    // SLICE 1: THE HUNTER GLOWS (Formerly the Cage)
    // ========================================================
    else if (id >= pc.offsets[1] && id < pc.offsets[1] + pc.counts[1]) {
        uint local_id = id - pc.offsets[1];
        uint h = pcg_hash(local_id);

        // 1. Pick a random CPU particle to hunt
        uint target_cpu_id = pc.offsets[0] + (h % pc.counts[0]);
        vec3 targetPos = vec3(inParticles[target_cpu_id].x, inParticles[target_cpu_id].y, inParticles[target_cpu_id].z);

        // 2. Generate a sweeping, organic noise cloud around the target
        float noiseX = sin(pc.time * 0.5 + float(local_id * 0.1)) * 3000.0;
        float noiseY = cos(pc.time * 0.3 + float(local_id * 0.05)) * 3000.0;
        float noiseZ = sin(pc.time * 0.4 - float(local_id * 0.1)) * 3000.0;
        vec3 idealPos = targetPos + vec3(noiseX, noiseY, noiseZ);

        // 3. Smooth Pursuit: Blend our current position towards the ideal position
        // This gives them a beautiful, flocking inertia!
        finalPos = mix(myPos, idealPos, 0.02);
        materialID = 1.0; // Ghostly orange hunters
    }
    // ========================================================
    // SLICE 2: TETHERED GPU BOIDS (Organic Flow)
    // ========================================================
    else if (id >= pc.offsets[2] && id < pc.offsets[2] + pc.counts[2]) {
        uint local_id = id - pc.offsets[2];
        uint target_cpu_id = pc.offsets[0] + (local_id % pc.counts[0]);
        vec3 anchorPos = vec3(inParticles[target_cpu_id].x, inParticles[target_cpu_id].y, inParticles[target_cpu_id].z);

        uint h = pcg_hash(local_id);
        float rand1 = float(h & 0xFFFF) / 65535.0;
        float rand2 = float((h >> 16) & 0xFFFF) / 65535.0;

        float radius = 100.0 + (rand1 * 400.0);
        float speed = 2.0 + (rand2 * 4.0);
        float angle = (rand2 * 6.28318) + (pc.time * speed);

        vec3 idealPos;
        idealPos.x = anchorPos.x + cos(angle) * radius;
        idealPos.y = anchorPos.y + sin(pc.time * 5.0 + float(local_id) * 0.1) * 150.0;
        idealPos.z = anchorPos.z + sin(angle) * radius;

        // Smooth out the orbits using inertia so they don't teleport if the CPU shifts rapidly
        finalPos = mix(myPos, idealPos, 0.08);
        materialID = 2.0; // Purple Traffic
    }
    // ========================================================
    // SLICE 3: GPU METEORS (Dynamic Roamers)
    // ========================================================
    else if (id >= pc.offsets[3] && id < pc.offsets[3] + pc.counts[3]) {
        uint local_id = id - pc.offsets[3];
        uint h = pcg_hash(local_id);
        
        // Meteors continuously fall from their current position
        float speed = 2000.0 + (float(h % 1000) / 1000.0) * 4000.0;
        finalPos = myPos + vec3(0.0, -speed * pc.dt, 0.0);

        // If they fall below the world, warp them organically to a new CPU target
        if (finalPos.y < -15000.0) {
            uint target_cpu_id = pc.offsets[0] + (local_id % pc.counts[0]);
            vec3 targetPos = vec3(inParticles[target_cpu_id].x, inParticles[target_cpu_id].y, inParticles[target_cpu_id].z);
            
            finalPos = targetPos + vec3(
                sin(float(h)) * 5000.0, 
                40000.0 + (float(h % 5000)), // High in the sky
                cos(float(h)) * 5000.0
            );
        }

        materialID = 3.0; // Base Meteor Color
    }

    // ========================================================
    // THE TEMPORAL LOCKSTEP FUSION
    // ========================================================
    uint myCell = GetCellIndex(finalPos);
    uint pastNeighborID = gridP[myCell];

    if (pastNeighborID != 0 && pastNeighborID != (id + 1)) {
        uint actualNeighborID = pastNeighborID - 1; 

        // THE MEMORY HEIST
        vec3 intruderPos = vec3(inParticles[actualNeighborID].x, 
                                inParticles[actualNeighborID].y, 
                                inParticles[actualNeighborID].z);

        // --- FUSION A: THE HUNTERS DETECT PREY ---
        if (id >= pc.offsets[1] && id < pc.offsets[1] + pc.counts[1]) {
            if (actualNeighborID < pc.offsets[1] || actualNeighborID >= pc.offsets[1] + pc.counts[1]) {
                // Instantly snap the hunter's inertia to the prey's location
                finalPos = mix(finalPos, intruderPos, 0.5); 
                materialID = 4.0; // Flash bright Cyan (Eating prey)
            }
        }
        
        // --- FUSION B: CPU CORE IMPACT SHOCKWAVES ---
        else if (id >= pc.offsets[0] && id < pc.offsets[0] + pc.counts[0]) {
            if (actualNeighborID >= pc.offsets[3]) {
                // Create a smooth repelling shockwave instead of an infinite drop
                vec3 pushDir = normalize(finalPos - intruderPos);
                finalPos += pushDir * 600.0; // Organic push
                materialID = 3.0;            // Flash red
            } else {
                materialID = 2.0; 
            }
        }
        
        // --- FUSION C: SPARKS ---
        else {
            materialID = 3.0; 
        }
    }

    atomicExchange(gridF[myCell], id + 1);

    outParticles[id].x = finalPos.x;
    outParticles[id].y = finalPos.y;
    outParticles[id].z = finalPos.z;
    outParticles[id].pad = materialID;

    if (id == 0) {
        drawCmd.vertexCount = pc.total_active_count;
        drawCmd.instanceCount = 1;
        drawCmd.firstVertex = 0;
        drawCmd.firstInstance = 0;
    }
}
